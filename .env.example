# ──────────────────────────────────────────────
# Night-Journal — 环境变量模板
# 复制为 .env 并填写真实值后启动
# ──────────────────────────────────────────────

# JWT 签名密钥（必填，至少 32 位随机字符串）
# 生成方式：openssl rand -hex 32
APP_SECRET=

# MySQL 连接串（必填）
# Docker Compose 默认值：mysql://nightjournal:nightjournal@db:3306/nightjournal
# 本地开发示例：mysql://root:password@localhost:3306/nightjournal
DATABASE_URL=

# 管理员账号 union_id（可选，留空则无管理员；
# 本地账号格式为 local:<username>）
OWNER_UNION_ID=

# 服务端口（可选，默认 3000）
PORT=3000

# ── 定时日记生成（可选） ────────────────────────
# 开发模式下启用自动日记生成调度器（生产环境默认启用）
# ENABLE_AUTO_GENERATION_IN_DEV=true

# ── Docker Compose 专用 ───────────────────────
# MySQL root 密码（仅 docker-compose 使用）
MYSQL_ROOT_PASSWORD=root
# MySQL 应用账号密码（与 DATABASE_URL 中保持一致）
MYSQL_PASSWORD=nightjournal
